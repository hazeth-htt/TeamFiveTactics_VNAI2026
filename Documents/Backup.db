-- Thiết lập Encoding và Search Path
SET client_encoding = 'UTF8';
SET standard_conforming_strings = 'on';
SELECT pg_catalog.set_config('search_path', '', false);

-- ==========================================
-- 1. TẠO CÁC SEQUENCE TỰ TĂNG CHO KHÓA CHÍNH
-- ==========================================
CREATE SEQUENCE public.career_tracks_id_seq AS integer START WITH 1 INCREMENT BY 1 NO MINVALUE NO MAXVALUE CACHE 1;
CREATE SEQUENCE public.conversation_messages_id_seq AS integer START WITH 1 INCREMENT BY 1 NO MINVALUE NO MAXVALUE CACHE 1;
CREATE SEQUENCE public.roadmaps_id_seq AS integer START WITH 1 INCREMENT BY 1 NO MINVALUE NO MAXVALUE CACHE 1;
CREATE SEQUENCE public.role_progressions_id_seq AS integer START WITH 1 INCREMENT BY 1 NO MINVALUE NO MAXVALUE CACHE 1;
CREATE SEQUENCE public.skill_trees_id_seq AS integer START WITH 1 INCREMENT BY 1 NO MINVALUE NO MAXVALUE CACHE 1;
CREATE SEQUENCE public.user_profiles_id_seq AS integer START WITH 1 INCREMENT BY 1 NO MINVALUE NO MAXVALUE CACHE 1;
CREATE SEQUENCE public.users_id_seq AS integer START WITH 1 INCREMENT BY 1 NO MINVALUE NO MAXVALUE CACHE 1;

-- ==========================================
-- 2. TẠO CÁC BẢNG (TABLES)
-- ==========================================
CREATE TABLE public.career_tracks (
    id integer NOT NULL DEFAULT nextval('public.career_tracks_id_seq'::regclass),
    career_track character varying(100) NOT NULL,
    track_type character varying(50) NOT NULL,
    description text,
    avg_salary_min integer,
    avg_salary_max integer,
    education_route text,
    typical_employers text[],
    region_demand jsonb,
    vector_id character varying(100),
    created_at timestamp without time zone DEFAULT now(),
    local_demand_signals jsonb,
    timeline_trends jsonb,
    embedding jsonb
);

CREATE TABLE public.role_progressions (
    id integer NOT NULL DEFAULT nextval('public.role_progressions_id_seq'::regclass),
    career_track_id integer NOT NULL,
    level character varying(20) NOT NULL,
    title character varying(150) NOT NULL,
    description text,
    sort_order integer DEFAULT 0,
    CONSTRAINT role_progressions_level_check CHECK (((level)::text = ANY ((ARRAY['Entry'::character varying, 'Mid'::character varying, 'Advanced'::character varying])::text[])))
);

CREATE TABLE public.skill_trees (
    id integer NOT NULL DEFAULT nextval('public.skill_trees_id_seq'::regclass),
    career_track_id integer NOT NULL,
    category character varying(50) NOT NULL,
    skill_name character varying(100) NOT NULL,
    CONSTRAINT skill_trees_category_check CHECK (((category)::text = ANY ((ARRAY['fundamentals'::character varying, 'core_technologies'::character varying, 'advanced_skills'::character varying])::text[])))
);

CREATE TABLE public.users (
    id integer NOT NULL DEFAULT nextval('public.users_id_seq'::regclass),
    username character varying(100),
    email character varying(255) NOT NULL,
    password_hash character varying(255) NOT NULL,
    anonymous_id uuid,
    created_at timestamp without time zone DEFAULT now()
);

CREATE TABLE public.sessions (
    id uuid DEFAULT gen_random_uuid() NOT NULL,
    user_id integer,
    started_at timestamp without time zone DEFAULT now(),
    ended_at timestamp without time zone,
    is_complete boolean DEFAULT false
);

CREATE TABLE public.conversation_messages (
    id integer NOT NULL DEFAULT nextval('public.conversation_messages_id_seq'::regclass),
    session_id uuid NOT NULL,
    role character varying(10) NOT NULL,
    content text NOT NULL,
    created_at timestamp without time zone DEFAULT now(),
    CONSTRAINT conversation_messages_role_check CHECK (((role)::text = ANY ((ARRAY['user'::character varying, 'assistant'::character varying])::text[])))
);

CREATE TABLE public.user_profiles (
    id integer NOT NULL DEFAULT nextval('public.user_profiles_id_seq'::regclass),
    session_id uuid NOT NULL,
    trait_scores jsonb,
    confidence_scores jsonb,
    is_ready boolean DEFAULT false,
    updated_at timestamp without time zone DEFAULT now()
);

CREATE TABLE public.roadmaps (
    id integer NOT NULL DEFAULT nextval('public.roadmaps_id_seq'::regclass),
    session_id uuid NOT NULL,
    user_profile_summary text,
    paths jsonb NOT NULL,
    disclaimer text NOT NULL,
    generated_at timestamp without time zone DEFAULT now()
);

-- ==========================================
-- 3. GẮN SEQUENCE VÀO BẢNG
-- ==========================================
ALTER SEQUENCE public.career_tracks_id_seq OWNED BY public.career_tracks.id;
ALTER SEQUENCE public.conversation_messages_id_seq OWNED BY public.conversation_messages.id;
ALTER SEQUENCE public.roadmaps_id_seq OWNED BY public.roadmaps.id;
ALTER SEQUENCE public.role_progressions_id_seq OWNED BY public.role_progressions.id;
ALTER SEQUENCE public.skill_trees_id_seq OWNED BY public.skill_trees.id;
ALTER SEQUENCE public.user_profiles_id_seq OWNED BY public.user_profiles.id;
ALTER SEQUENCE public.users_id_seq OWNED BY public.users.id;

-- ==========================================
-- 4. THIẾT LẬP KHÓA CHÍNH (PRIMARY KEYS) VÀ RÀNG BUỘC UNIQUE
-- ==========================================
ALTER TABLE ONLY public.career_tracks ADD CONSTRAINT career_tracks_pkey PRIMARY KEY (id);
ALTER TABLE ONLY public.conversation_messages ADD CONSTRAINT conversation_messages_pkey PRIMARY KEY (id);
ALTER TABLE ONLY public.roadmaps ADD CONSTRAINT roadmaps_pkey PRIMARY KEY (id);
ALTER TABLE ONLY public.roadmaps ADD CONSTRAINT roadmaps_session_id_key UNIQUE (session_id);
ALTER TABLE ONLY public.role_progressions ADD CONSTRAINT role_progressions_pkey PRIMARY KEY (id);
ALTER TABLE ONLY public.sessions ADD CONSTRAINT sessions_pkey PRIMARY KEY (id);
ALTER TABLE ONLY public.skill_trees ADD CONSTRAINT skill_trees_pkey PRIMARY KEY (id);
ALTER TABLE ONLY public.user_profiles ADD CONSTRAINT user_profiles_pkey PRIMARY KEY (id);
ALTER TABLE ONLY public.user_profiles ADD CONSTRAINT user_profiles_session_id_key UNIQUE (session_id);
ALTER TABLE ONLY public.users ADD CONSTRAINT users_pkey PRIMARY KEY (id);
ALTER TABLE ONLY public.users ADD CONSTRAINT users_anonymous_id_key UNIQUE (anonymous_id);
ALTER TABLE ONLY public.users ADD CONSTRAINT users_email_key UNIQUE (email);
ALTER TABLE ONLY public.users ADD CONSTRAINT users_username_key UNIQUE (username);

-- ==========================================
-- 5. THIẾT LẬP KHÓA NGOẠI (FOREIGN KEYS)
-- ==========================================
ALTER TABLE ONLY public.conversation_messages 
    ADD CONSTRAINT conversation_messages_session_id_fkey FOREIGN KEY (session_id) REFERENCES public.sessions(id) ON DELETE CASCADE;

ALTER TABLE ONLY public.roadmaps 
    ADD CONSTRAINT roadmaps_session_id_fkey FOREIGN KEY (session_id) REFERENCES public.sessions(id) ON DELETE CASCADE;

ALTER TABLE ONLY public.role_progressions 
    ADD CONSTRAINT role_progressions_career_track_id_fkey FOREIGN KEY (career_track_id) REFERENCES public.career_tracks(id) ON DELETE CASCADE;

ALTER TABLE ONLY public.sessions 
    ADD CONSTRAINT sessions_user_id_fkey FOREIGN KEY (user_id) REFERENCES public.users(id) ON DELETE SET NULL;

ALTER TABLE ONLY public.skill_trees 
    ADD CONSTRAINT skill_trees_career_track_id_fkey FOREIGN KEY (career_track_id) REFERENCES public.career_tracks(id) ON DELETE CASCADE;

ALTER TABLE ONLY public.user_profiles 
    ADD CONSTRAINT user_profiles_session_id_fkey FOREIGN KEY (session_id) REFERENCES public.sessions(id) ON DELETE CASCADE;

-- ==========================================
-- 6. RESET LẠI CÁC SEQUENCE
-- ==========================================
SELECT pg_catalog.setval('public.career_tracks_id_seq', 131, true);
SELECT pg_catalog.setval('public.conversation_messages_id_seq', 1, false);
SELECT pg_catalog.setval('public.roadmaps_id_seq', 1, false);
SELECT pg_catalog.setval('public.role_progressions_id_seq', 439, true);
SELECT pg_catalog.setval('public.skill_trees_id_seq', 1420, true);
SELECT pg_catalog.setval('public.user_profiles_id_seq', 1, false);
SELECT pg_catalog.setval('public.users_id_seq', 1, false);

